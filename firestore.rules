rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isStaff() {
      return request.auth != null;
    }

    function allowedTicketKeys() {
      return request.resource.data.keys().hasOnly([
        'ticketId',
        'fullName',
        'email',
        'phone',
        'ticketType',
        'ticketPrice',
        'paymentMethod',
        'purchaseDate',
        'checkedIn',
        'checkInTime',
        'groupSize',
        'ticketNumber',
        'webhookProcessed'
      ]);
    }

    function validTicketId(ticketId) {
      return ticketId.matches('^SAPE2026-[A-Z0-9]{8}$');
    }

    function validEmail(email) {
      return email is string && email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
    }

    function validPhone(phone) {
      return phone is string && phone.matches('^\\+?[0-9]{10,15}$');
    }

    function isEarlyBirdValid() {
      return request.time < timestamp("2026-04-18T00:00:00Z");
    }

    function validTicketType(type, price) {
      return (
        (type == 'Early Bird - KES 3,000 (Available for 9 days only)' && price == 3000 && isEarlyBirdValid()) ||
        (type == 'Standard - KES 5,000' && price == 5000) ||
        (type == 'VIP - KES 10,000' && price == 10000) ||
        (type == 'VVIP - KES 20,000' && price == 20000) ||
        (type == 'Organizer (Complimentary) - KES 0' && price == 0)
      );
    }

    function validStaffUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['checkedIn', 'checkInTime'])
        && request.resource.data.ticketId == resource.data.ticketId
        && request.resource.data.fullName == resource.data.fullName
        && request.resource.data.email == resource.data.email
        && request.resource.data.phone == resource.data.phone
        && request.resource.data.ticketType == resource.data.ticketType
        && request.resource.data.ticketPrice == resource.data.ticketPrice
        && request.resource.data.paymentMethod == resource.data.paymentMethod
        && request.resource.data.purchaseDate == resource.data.purchaseDate
        && request.resource.data.groupSize == resource.data.groupSize
        && request.resource.data.ticketNumber == resource.data.ticketNumber
        && request.resource.data.checkedIn is bool
        && (
          (request.resource.data.checkedIn == false && request.resource.data.checkInTime == null) ||
          (request.resource.data.checkedIn == true && request.resource.data.checkInTime is string)
        );
    }

    match /tickets/{ticketId} {
      allow create: if false;
      allow read: if isStaff();
      allow update: if isStaff() && validStaffUpdate();
      allow delete: if isStaff();
    }

    match /settings/{document} {
      allow read, write: if isStaff();
    }

    match /staff/{userId} {
      allow read, write: if isStaff();
    }

    match /_rate_limits/{document} {
      allow read, write: if false;
    }

    // pending_orders: only writable by Cloud Functions via Admin SDK.
    // No direct browser access is permitted.
    match /pending_orders/{orderId} {
      allow read, write: if false;
    }
  }
}
